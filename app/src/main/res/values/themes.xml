<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.紫罗兰检测" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/ios_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/ios_card</item>
        <item name="android:colorBackground">@color/ios_background_grouped</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="Theme.紫罗兰检测" parent="Base.Theme.紫罗兰检测" />

    <style name="Widget.IOS.SectionLabel" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/ios_text_secondary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.IOS.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/ios_text_primary</item>
        <item name="android:lineSpacingMultiplier">1.15</item>
    </style>

    <style name="Widget.IOS.SubsectionTitle" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/ios_accent</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.IOS.Caption" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/ios_text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- 玩机页（stitch code.html） -->
    <!-- stitch_fluent_root_system/code.html：section 标题 slate-500、uppercase -->
    <style name="Widget.IOS.ExploreSectionTitle" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/explore_slate_500</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- code.html 快捷重启标签 text-slate-600 -->
    <style name="Widget.IOS.ExploreQuickLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/explore_slate_600</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="ThemeOverlay.Violet.ToolbarPopup" parent="ThemeOverlay.Material3.Light">
        <item name="android:popupBackground">@drawable/bg_toolbar_popup_menu</item>
    </style>
</resources>
