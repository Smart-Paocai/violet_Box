<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background_grouped"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ios_background_elevated"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:menu="@menu/toolbar_menu"
            app:title="紫罗兰Box v1.0.0beta"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="@color/ios_text_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ios_separator" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ios_screen_edge"
            android:paddingTop="8dp"
            android:paddingBottom="28dp">

            <!-- 设备信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="6dp"
                android:text="设备信息"
                android:textAppearance="@style/Widget.IOS.SectionLabel" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeviceInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ios_section_gap"
                app:cardBackgroundColor="@color/ios_card"
                app:cardCornerRadius="@dimen/ios_card_corner"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_card_padding">
                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="设备名称: 加载中..." />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />
                    <TextView
                        android:id="@+id/tvDeviceCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="设备代号: 加载中..." />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />
                    <TextView
                        android:id="@+id/tvAndroidVersion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="安卓版本: 加载中..." />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />
                    <TextView
                        android:id="@+id/tvKernelVersion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="内核版本: 加载中..." />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />
                    <TextView
                        android:id="@+id/tvSelinuxStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="SELinux状态: 加载中..." />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />
                    <TextView
                        android:id="@+id/tvBootSlot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="启动槽位: 加载中..." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEnvironmentSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ios_section_gap"
                android:layout_marginHorizontal="2dp"
                app:cardBackgroundColor="@color/ios_glass_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_glass_stroke"
                app:strokeWidth="1dp"
                app:cardUseCompatPadding="true"
                app:cardPreventCornerOverlap="true">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">
                    <TextView
                        android:id="@+id/tvEnvironmentSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅正常设备"
                        android:textColor="#1E5AA8"
                        android:textAppearance="@style/Widget.IOS.Body"
                        android:textStyle="bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="Root 与安全检测"
                android:textAppearance="@style/Widget.IOS.SectionLabel" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRootInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card"
                app:cardCornerRadius="@dimen/ios_card_corner"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_card_padding">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="风险检测总览"
                        android:textAppearance="@style/Widget.IOS.SubsectionTitle" />
                    <TextView
                        android:id="@+id/tvRiskApps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="风险应用: 加载中..." />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/ios_separator" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="检测明细"
                        android:textAppearance="@style/Widget.IOS.SubsectionTitle" />
                    <TextView
                        android:id="@+id/tvRootOverall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:textAppearance="@style/Widget.IOS.Body"
                        android:textStyle="bold"
                        tools:text="综合状态: 加载中..." />
                    <LinearLayout
                        android:id="@+id/layoutRootDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp" />
                    <LinearLayout
                        android:id="@+id/layoutAdvancedDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp" />
                    <TextView
                        android:id="@+id/tvBootloader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="Bootloader锁: 加载中..." />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />
                    <TextView
                        android:id="@+id/tvUsbDebug"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="USB调试: 加载中..." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <include
        android:id="@+id/fragmentSettingsPlaceholder"
        layout="@layout/fragment_settings_placeholder"
        android:visibility="gone" />

    <!-- 底部导航栏  -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="4dp"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="@color/ios_glass_surface"
        app:cardCornerRadius="35dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/ios_glass_stroke"
        app:strokeWidth="1dp"
        app:cardUseCompatPadding="true"
        app:cardPreventCornerOverlap="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:paddingStart="0.5dp"
            android:paddingEnd="0.5dp"
            android:gravity="center">

            <View
                android:id="@+id/nav_liquid_indicator"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/nav_item_active_wrap" />

            <LinearLayout
                android:id="@+id/nav_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center">

            <!-- 首页页面 -->
            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_home_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/nav_home_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="首页"
                    android:textSize="9sp"
                    android:textColor="@color/ios_text_primary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 设备信息页面 -->
            <LinearLayout
                android:id="@+id/nav_device"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_device_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_device_info"
                    app:tint="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/nav_device_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备"
                    android:textSize="9sp"
                    android:textColor="@color/ios_text_primary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 玩机页面 -->
            <LinearLayout
                android:id="@+id/nav_explore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_explore_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_explore"
                    app:tint="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/nav_explore_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="玩机"
                    android:textSize="9sp"
                    android:textColor="@color/ios_text_primary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 设置页面 -->
            <LinearLayout
                android:id="@+id/nav_settings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_settings_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/nav_settings_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设置"
                    android:textSize="9sp"
                    android:textColor="@color/ios_text_primary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            </LinearLayout>
        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
