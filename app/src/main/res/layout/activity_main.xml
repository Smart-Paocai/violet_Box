<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background_grouped"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ios_background_elevated"
        android:elevation="8dp"
        android:translationZ="8dp"
        app:elevation="8dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/ios_background_elevated"
            app:menu="@menu/toolbar_menu"
            app:title="紫罗兰Box"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="@color/ios_text_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ios_separator" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentHome"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ios_screen_edge"
            android:paddingTop="8dp"
            android:paddingBottom="28dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEnvironmentSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ios_section_gap"
                app:cardBackgroundColor="@color/ios_glass_surface"
                app:cardCornerRadius="@dimen/ios_card_corner"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_glass_stroke"
                app:strokeWidth="1dp"
                app:cardUseCompatPadding="false"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="25dp">

                    <!-- 状态图标 -->
                    <ImageView
                        android:id="@+id/ivEnvironmentIcon"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/ic_safe" />

                    <!-- 状态文字 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvEnvironmentSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="设备安全"
                            android:textColor="@color/ios_semantic_positive"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvEnvironmentDetail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="未检测到安全风险"
                            android:textColor="@color/ios_text_secondary"
                            android:textSize="14sp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRootInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card"
                app:cardCornerRadius="@dimen/ios_card_corner"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_card_padding">
                    <TextView
                        android:id="@+id/tvRiskApps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="风险应用: 加载中..." />
                    <LinearLayout
                        android:id="@+id/layoutRootDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <LinearLayout
                        android:id="@+id/layoutAdvancedDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                    <TextView
                        android:id="@+id/tvBootloader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="Bootloader锁: 加载中..." />
                    <TextView
                        android:id="@+id/tvUsbDebug"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="USB调试: 加载中..." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSystemPropsPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/ios_section_gap"
                android:visibility="gone"
                app:cardBackgroundColor="@color/ios_card"
                app:cardCornerRadius="@dimen/ios_card_corner"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="系统属性"
                        android:textAppearance="@style/Widget.IOS.SubsectionTitle" />

                    <TextView
                        android:id="@+id/tvSystemPropsPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="2dp"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="品牌: Xiaomi\n型号: 23127PN0CC\n系统版本: Android 15 (API 35)\n构建指纹: ...\nro.secure: 1" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- “设备”导航：使用 DeviceFragment 加载 fragment_device.xml -->
    <FrameLayout
        android:id="@+id/contentDevice"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/device_fragment_container"
            android:name="com.violet.safe.fragment.DeviceFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <include
        android:id="@+id/fragmentExplorePlaceholder"
        layout="@layout/fragment_explore_placeholder"
        android:layout_marginTop="?attr/actionBarSize"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <include
        android:id="@+id/fragmentSettingsPlaceholder"
        layout="@layout/fragment_settings_placeholder"
        android:layout_marginTop="?attr/actionBarSize"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- 底部导航栏  -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="4dp"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="@color/ios_glass_surface"
        app:cardCornerRadius="35dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/ios_glass_stroke"
        app:strokeWidth="1dp"
        app:cardUseCompatPadding="true"
        app:cardPreventCornerOverlap="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="0dp"
            android:paddingBottom="0dp"
            android:paddingStart="0.5dp"
            android:paddingEnd="0.5dp"
            android:gravity="center">

            <View
                android:id="@+id/nav_liquid_indicator"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_gravity="start|center_vertical"
                android:background="@drawable/nav_item_active_wrap" />

            <LinearLayout
                android:id="@+id/nav_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:gravity="center">

            <!-- 首页页面 -->
            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_home_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_device_info"
                    app:tint="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/nav_home_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备"
                    android:textSize="9sp"
                    android:textColor="@color/ios_text_primary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 设备信息页面 -->
            <LinearLayout
                android:id="@+id/nav_device"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_device_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_ms_selinux"
                    app:tint="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/nav_device_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="安全"
                    android:textSize="9sp"
                    android:textColor="@color/ios_text_primary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 玩机页面 -->
            <LinearLayout
                android:id="@+id/nav_explore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_explore_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_explore"
                    app:tint="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/nav_explore_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="玩机"
                    android:textSize="9sp"
                    android:textColor="@color/ios_text_primary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 设置页面 -->
            <LinearLayout
                android:id="@+id/nav_settings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="6dp"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_settings_icon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/nav_settings_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设置"
                    android:textSize="9sp"
                    android:textColor="@color/ios_text_primary"
                    android:layout_marginTop="2dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            </LinearLayout>
        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
