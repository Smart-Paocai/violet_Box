<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background_grouped"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ios_background_elevated"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:menu="@menu/toolbar_menu"
            app:title="紫罗兰Box v1.0.0beta"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="@color/ios_text_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ios_separator" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:overScrollMode="never"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ios_screen_edge"
            android:paddingTop="8dp"
            android:paddingBottom="28dp">

            <!-- 设备信息 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="6dp"
                android:text="设备信息"
                android:textAppearance="@style/Widget.IOS.SectionLabel" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDeviceInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ios_section_gap"
                app:cardBackgroundColor="@color/ios_card"
                app:cardCornerRadius="@dimen/ios_card_corner"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_card_padding">

                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="设备名称: 加载中..." />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />

                    <TextView
                        android:id="@+id/tvDeviceCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="设备代号: 加载中..." />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />

                    <TextView
                        android:id="@+id/tvAndroidVersion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="安卓版本: 加载中..." />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />

                    <TextView
                        android:id="@+id/tvKernelVersion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="内核版本: 加载中..." />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />

                    <TextView
                        android:id="@+id/tvSelinuxStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="SELinux状态: 加载中..." />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />

                    <TextView
                        android:id="@+id/tvBootSlot"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="启动槽位: 加载中..." />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEnvironmentSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/ios_section_gap"
                android:layout_marginHorizontal="2dp"
                app:cardBackgroundColor="#EAF4FF"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="#B9D7F5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/tvEnvironmentSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅正常设备"
                        android:textColor="#1E5AA8"
                        android:textAppearance="@style/Widget.IOS.Body"
                        android:textStyle="bold" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Root 与安全 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:text="Root 与安全检测"
                android:textAppearance="@style/Widget.IOS.SectionLabel" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRootInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card"
                app:cardCornerRadius="@dimen/ios_card_corner"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="风险检测总览"
                        android:textAppearance="@style/Widget.IOS.SubsectionTitle" />

                    <TextView
                        android:id="@+id/tvRiskApps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="风险应用: 加载中..." />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="14dp"
                        android:background="@color/ios_separator" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="检测明细"
                        android:textAppearance="@style/Widget.IOS.SubsectionTitle" />

                    <TextView
                        android:id="@+id/tvRootOverall"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:textAppearance="@style/Widget.IOS.Body"
                        android:textStyle="bold"
                        tools:text="综合状态: 加载中..." />

                    <LinearLayout
                        android:id="@+id/layoutRootDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:id="@+id/layoutAdvancedDetails"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tvBootloader"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="Bootloader锁: 加载中..." />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:layout_marginBottom="@dimen/ios_row_spacing"
                        android:background="@color/ios_separator" />

                    <TextView
                        android:id="@+id/tvUsbDebug"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textAppearance="@style/Widget.IOS.Body"
                        tools:text="USB调试: 加载中..." />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
