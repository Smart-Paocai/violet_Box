<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/fluent_cell_bg"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="6dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/tvCpuCoreLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:letterSpacing="0.04"
        android:textColor="@color/fluent_on_surface_variant"
        android:textSize="9sp"
        android:textStyle="bold"
        tools:text="核心 0" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:clipChildren="false">

        <com.violet.safe.widget.CpuRingGaugeView
            android:id="@+id/cpuRingGauge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            app:gaugeStyle="donut" />

        <TextView
            android:id="@+id/tvCpuCorePct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:includeFontPadding="false"
            android:textColor="@color/fluent_on_surface"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="57%" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="bottom|center_horizontal"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvCpuCoreFreq"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/fluent_on_surface"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="1152" />

        <TextView
            android:id="@+id/tvCpuCoreFreqUnit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="MHz"
            android:textColor="@color/fluent_on_surface_variant"
            android:textSize="9sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvCpuCoreFreqRange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/fluent_on_surface_variant"
        android:textSize="8sp"
        tools:text="300–2016 MHz" />
</LinearLayout>
