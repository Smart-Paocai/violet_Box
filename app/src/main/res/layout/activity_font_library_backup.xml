<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background_grouped"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/ios_background_elevated"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarFontBackup"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:title="字库备份"
            app:titleTextColor="@color/ios_text_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/ios_separator" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/ios_screen_edge"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card"
                app:cardCornerRadius="@dimen/ios_card_corner"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/ios_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="说明"
                        android:textAppearance="@style/Widget.IOS.SubsectionTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="本功能需要ROOT权限，备份完整字库需要确保设备存储空间不低于20GB，不建议备份Super动态分区，该分区体积较大，且不属于底层分区，在设备损坏后刷入底层分区后使用任意线刷包均可替代当前Super，不排除Super可能备份时间较长"
                        android:textAppearance="@style/Widget.IOS.Body" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchExcludeSuper"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:checked="true"
                        android:text="排除super"
                        android:textAppearance="@style/Widget.IOS.Body" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchCompressPack"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:checked="true"
                        android:text="备份完后压缩（耗时长，体积小）"
                        android:textAppearance="@style/Widget.IOS.Body" />

                    <TextView
                        android:id="@+id/tvFontBackupStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="状态：就绪"
                        android:textAppearance="@style/Widget.IOS.Body" />

                    <ProgressBar
                        android:id="@+id/progressFontBackup"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="10dp"
                        android:max="100"
                        android:progress="0"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvFontBackupProgress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="end"
                        android:text="进度：0%"
                        android:textAppearance="@style/Widget.IOS.Caption"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnFontBackupExport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="选择保存位置并备份"
                        android:textAllCaps="false"
                        android:textColor="@color/ios_text_primary"
                        app:backgroundTint="@color/ios_background_elevated"
                        app:cornerRadius="14dp"
                        app:strokeColor="@color/ios_separator"
                        app:strokeWidth="1dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
