<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- 顶部标题栏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F3E5F5"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="紫罗兰检测"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleMedium"
            android:background="@android:color/transparent"
            app:titleTextColor="#4A148C" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Fragment容器 -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:layout_marginBottom="80dp" />

    <!-- iOS风格底部导航栏 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottom_nav_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#F0F3E5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:gravity="center">

            <!-- 首页页面 -->
            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="@drawable/nav_item_selector"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_home_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_home"
                    app:tint="#4A148C" />

                <TextView
                    android:id="@+id/nav_home_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="首页"
                    android:textSize="11sp"
                    android:textColor="#4A148C"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 设备信息页面 -->
            <LinearLayout
                android:id="@+id/nav_device"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="@drawable/nav_item_selector"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_device_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_device_info"
                    app:tint="#757575" />

                <TextView
                    android:id="@+id/nav_device_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设备"
                    android:textSize="11sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 玩机页面 -->
            <LinearLayout
                android:id="@+id/nav_explore"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="@drawable/nav_item_selector"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_explore_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_explore"
                    app:tint="#757575" />

                <TextView
                    android:id="@+id/nav_explore_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="玩机"
                    android:textSize="11sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- 设置页面 -->
            <LinearLayout
                android:id="@+id/nav_settings"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp"
                android:background="@drawable/nav_item_selector"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/nav_settings_icon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_settings"
                    app:tint="#757575" />

                <TextView
                    android:id="@+id/nav_settings_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="设置"
                    android:textSize="11sp"
                    android:textColor="#757575"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
