<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background_grouped"
    android:clipToPadding="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/ios_screen_edge"
        android:paddingTop="16dp"
        android:paddingBottom="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ios_card"
            app:cardCornerRadius="@dimen/ios_card_corner"
            app:cardElevation="0dp"
            app:strokeColor="@color/ios_glass_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="@dimen/ios_card_padding">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_avatar_circle"
                    android:clipToOutline="true"
                    android:contentDescription="作者头像"
                    android:outlineProvider="background"
                    android:scaleType="centerCrop"
                    android:src="@drawable/about_avatar" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="该项目由哔哩哔哩UP主“泡菜学不会”开发，开发此项目希望能为安卓玩机生态贡献自己的一份力量。"
                    android:textAppearance="@style/Widget.IOS.Body"
                    android:textColor="@color/ios_text_secondary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/iconAboutLink1"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginHorizontal="12dp"
                        android:contentDescription="平台图标1"
                        android:src="@drawable/ic_about_logo_1" />

                    <ImageView
                        android:id="@+id/iconAboutLink2"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginHorizontal="12dp"
                        android:contentDescription="平台图标2"
                        android:src="@drawable/ic_about_logo_2" />

                    <ImageView
                        android:id="@+id/iconAboutLink3"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginHorizontal="12dp"
                        android:contentDescription="平台图标3"
                        android:src="@drawable/ic_github_logo" />

                    <ImageView
                        android:id="@+id/iconAboutLink4"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginHorizontal="12dp"
                        android:contentDescription="平台图标4"
                        android:src="@drawable/ic_about_logo_4" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/ios_card"
            app:cardCornerRadius="@dimen/ios_card_corner"
            app:cardElevation="0dp"
            app:strokeColor="@color/ios_glass_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/ios_card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="当前版本"
                    android:textAppearance="@style/Widget.IOS.SubsectionTitle"
                    android:textColor="@color/ios_text_primary" />

                <TextView
                    android:id="@+id/tvAboutCurrentVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="1.0.0"
                    android:textAppearance="@style/Widget.IOS.Body"
                    android:textColor="@color/ios_text_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="更新日期：2026.04.24"
                    android:textAppearance="@style/Widget.IOS.Body"
                    android:textColor="@color/ios_text_secondary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
