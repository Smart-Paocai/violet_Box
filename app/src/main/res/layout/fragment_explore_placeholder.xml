<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="top"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/ios_screen_edge"
    android:paddingTop="?attr/actionBarSize"
    android:paddingBottom="88dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/ios_card"
        app:cardCornerRadius="@dimen/ios_card_corner"
        app:cardElevation="0dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/ios_card_padding">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSelinuxManager"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SElinux管理"
                android:textAllCaps="false"
                android:textColor="@color/ios_text_primary"
                app:backgroundTint="@color/ios_background_elevated"
                app:cornerRadius="14dp"
                app:strokeColor="@color/ios_separator"
                app:strokeWidth="1dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
