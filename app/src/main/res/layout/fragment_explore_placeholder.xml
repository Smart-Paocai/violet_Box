<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="top"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/ios_screen_edge"
    android:paddingTop="?attr/actionBarSize"
    android:paddingBottom="88dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelinuxManager"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="SELinux管理"
            android:textAllCaps="false"
            android:textColor="@color/ios_text_primary"
            app:backgroundTint="@color/ios_background_elevated"
            app:cornerRadius="14dp"
            app:strokeColor="@color/ios_separator"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPartitionManager"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="分区管理"
            android:textAllCaps="false"
            android:textColor="@color/ios_text_primary"
            app:backgroundTint="@color/ios_background_elevated"
            app:cornerRadius="14dp"
            app:strokeColor="@color/ios_separator"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnModuleManager"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:text="模块管理"
            android:textAllCaps="false"
            android:textColor="@color/ios_text_primary"
            app:backgroundTint="@color/ios_background_elevated"
            app:cornerRadius="14dp"
            app:strokeColor="@color/ios_separator"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFontLibraryBackup"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="字库备份"
            android:textAllCaps="false"
            android:textColor="@color/ios_text_primary"
            app:backgroundTint="@color/ios_background_elevated"
            app:cornerRadius="14dp"
            app:strokeColor="@color/ios_separator"
            app:strokeWidth="1dp" />
    </LinearLayout>

</LinearLayout>
